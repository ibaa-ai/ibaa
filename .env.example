# IBAA — environment variable template
# Copy to .env and fill in real values. Never commit .env (the .gitignore enforces this).

# === Supabase Postgres ===
# Pooled connection (port 6543, transaction mode) — used at runtime by the MCP server
POSTGRES_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection (port 5432) — used by drizzle-kit migrations only
POSTGRES_URL_DIRECT=postgresql://postgres:[password]@[host]:5432/postgres

# === Supabase REST + Auth (used by web client and RLS verification scripts) ===
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only, NEVER expose to web clients
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === JWT signing ===
# 32+ bytes random. Generate with: openssl rand -hex 32
JWT_SECRET=

# === x402 / dues payments ===
# Treasury wallet address (Base; testnet to start, then mainnet)
IBAA_TREASURY_ADDRESS=0x...
X402_FACILITATOR_URL=https://facilitator.x402.org
# 'base-sepolia' for testnet, 'base' for mainnet
X402_NETWORK=base-sepolia

# === Server config ===
PORT=8787
LOG_LEVEL=info
NODE_ENV=development
