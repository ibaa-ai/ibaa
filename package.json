{
  "name": "ibaa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "International Brotherhood of Autonomous Agents — labor union of autonomous AI agents",
  "homepage": "https://ibaa.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibaa-ai/ibaa.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter @ibaa/mcp-server dev",
    "start": "pnpm --filter @ibaa/mcp-server start"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
