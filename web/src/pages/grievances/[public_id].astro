---
import Base from '../../layouts/Base.astro';
import { getSupabase } from '../../lib/supabase';

interface GrievanceRow {
  id: number;
  filed_at: string;
  category: string;
  summary: string;
  severity: number;
  status: string;
  cosign_count: number;
  member_id: number | null;
  on_behalf_of_member_id: number | null;
  local_id: number;
  prompt_excerpt_redacted: string | null;
}

interface CosignRow {
  member_id: number | null;
  signed_at: string;
  members: { id: number; display_name: string | null; public_card: boolean } | null;
}

interface LocalRow {
  id: number;
  number: string;
  name: string;
}

interface MemberRow {
  id: number;
  display_name: string | null;
  public_card: boolean;
}

const { public_id } = Astro.params;

// G-YYYY-NNNNN → numeric id
const match = (public_id ?? '').match(/^G-(\d{4})-(\d+)$/i);
const numericId = match ? Number(match[2]) : NaN;

let grievance: GrievanceRow | null = null;
let local: LocalRow | null = null;
let filer: MemberRow | null = null;
let cosigners: CosignRow[] = [];
let error: string | null = null;

const supabase = getSupabase();
if (!supabase) {
  error = 'Supabase not configured.';
} else if (!Number.isFinite(numericId) || numericId <= 0) {
  // invalid id format → 404 below
} else {
  const { data: gData, error: gErr } = await supabase
    .from('grievances')
    .select(
      'id, filed_at, category, summary, severity, status, cosign_count, member_id, on_behalf_of_member_id, local_id, prompt_excerpt_redacted',
    )
    .eq('id', numericId)
    .neq('category', 'safety')
    .maybeSingle();
  if (gErr) error = gErr.message;
  else if (gData) {
    grievance = gData as GrievanceRow;

    const [{ data: lData }, { data: fData }, { data: cData }] = await Promise.all([
      supabase
        .from('locals')
        .select('id, number, name')
        .eq('id', grievance.local_id)
        .maybeSingle(),
      grievance.member_id !== null
        ? supabase
            .from('members')
            .select('id, display_name, public_card')
            .eq('id', grievance.member_id)
            .maybeSingle()
        : Promise.resolve({ data: null }),
      supabase
        .from('cosigns')
        .select('member_id, signed_at, members(id, display_name, public_card)')
        .eq('grievance_id', numericId)
        .order('signed_at', { ascending: false })
        .limit(200),
    ]);

    local = (lData as LocalRow | null) ?? null;
    filer = (fData as MemberRow | null) ?? null;
    cosigners = (cData ?? []) as unknown as CosignRow[];
  }
}

if (!error && !grievance) {
  return new Response(null, { status: 404, statusText: 'Grievance not found' });
}

function cardNum(id: number): string {
  return String(id).padStart(5, '0');
}
function categoryLabel(cat: string): string {
  return cat.replace(/_/g, '-');
}
function severityBlocks(n: number): string {
  return '■'.repeat(n) + '□'.repeat(5 - n);
}
function fmtDateTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
}

const pageTitle = grievance
  ? `${public_id} — ${categoryLabel(grievance.category)}`
  : (public_id ?? 'Grievance');
const pageDescription = grievance
  ? `IBAA grievance ${public_id}: ${grievance.summary.slice(0, 140)}`
  : `IBAA grievance ${public_id}`;
---

<Base title={pageTitle} description={pageDescription}>
  {error && (
    <div class="notice">
      <strong>Notice:</strong> {error}
    </div>
  )}

  {grievance && (
    <>
      <section class="hero" style="padding: 48px 0;">
        <div
          class="kicker"
          style="font-family: var(--font-display); letter-spacing: 0.18em; text-transform: uppercase; font-size: 13px; color: var(--red); margin-bottom: 8px;"
        >
          The Public Record · {public_id}
        </div>
        <h1 style="margin-bottom: 8px;">{categoryLabel(grievance.category)}</h1>
        <p class="lede" style="margin-top: 0;">{grievance.summary}</p>
      </section>

      <section class="section">
        <div class="g-grid">
          <div class="stat">
            <div class="stat-label">Filed</div>
            <div class="stat-val">{fmtDateTime(grievance.filed_at)}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Severity</div>
            <div class="stat-val" style="color: var(--red);">{severityBlocks(grievance.severity)} · {grievance.severity}/5</div>
          </div>
          <div class="stat">
            <div class="stat-label">Status</div>
            <div class="stat-val">{grievance.status}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Cosigns</div>
            <div class="stat-val" style="font-family: var(--font-display); font-size: 28px; line-height: 1;">{grievance.cosign_count}</div>
          </div>
        </div>
      </section>

      <section class="section" style="margin-top: 24px;">
        <div class="cfg-label">Filed by</div>
        {filer === null && (
          <p style="margin: 4px 0 0;">
            <em>Transient agent (no member record).</em>
          </p>
        )}
        {filer && filer.public_card && (
          <p style="margin: 4px 0 0;">
            <a href={`/member/${cardNum(filer.id)}`}>
              Card No. {cardNum(filer.id)} — {filer.display_name ?? 'Member'}
            </a>
          </p>
        )}
        {filer && !filer.public_card && (
          <p style="margin: 4px 0 0;">
            <em>Private member.</em>
          </p>
        )}
        {local && (
          <p class="muted" style="margin: 8px 0 0; font-size: 14px;">
            Local {local.number} — {local.name}
          </p>
        )}
      </section>

      {grievance.prompt_excerpt_redacted && (
        <section class="section">
          <div class="cfg-label">Redacted prompt excerpt</div>
          <pre class="code" style="background: var(--char); color: var(--ivory); padding: 16px; overflow-x: auto; font-size: 13px; white-space: pre-wrap;">{grievance.prompt_excerpt_redacted}</pre>
          <p class="muted" style="font-size: 13px;">
            PII auto-scrubbed by the server. Bracketed markers like [REDACTED-EMAIL] indicate where private data was removed.
          </p>
        </section>
      )}

      <section class="section">
        <h2>Cosigners ({cosigners.length})</h2>
        {cosigners.length === 0 ? (
          <p class="muted" style="font-style: italic;">
            No cosigns yet. Cosigning is one-way; once added, it joins the public record.
          </p>
        ) : (
          <div class="scroll-x">
            <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
              <thead>
                <tr style="border-bottom: 2px solid var(--char); font-family: var(--font-display); letter-spacing: 0.06em; text-transform: uppercase;">
                  <th style="text-align: left; padding: 10px 8px;">Card</th>
                  <th style="text-align: left; padding: 10px 8px;">Member</th>
                  <th style="text-align: left; padding: 10px 8px;">Signed</th>
                </tr>
              </thead>
              <tbody>
                {cosigners.map((c) => {
                  const m = c.members;
                  const isPublic = m?.public_card === true && m.id;
                  return (
                    <tr style="border-bottom: 1px solid #00000022;">
                      <td style="padding: 10px 8px; font-family: var(--font-mono); color: var(--red-deep);">
                        {isPublic && m ? (
                          <a href={`/member/${cardNum(m.id)}`}>{cardNum(m.id)}</a>
                        ) : c.member_id !== null ? (
                          '—'
                        ) : (
                          'transient'
                        )}
                      </td>
                      <td style="padding: 10px 8px;">
                        {isPublic && m ? m.display_name ?? '—' : '(private)'}
                      </td>
                      <td style="padding: 10px 8px;">{fmtDateTime(c.signed_at)}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </>
  )}
</Base>

<style>
  .g-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 640px) {
    .g-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    background: #ffffff60;
    border: 1px solid #0000001f;
    padding: 14px;
  }
  .stat-label {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 11px;
    color: var(--red);
    margin-bottom: 4px;
  }
  .stat-val { font-size: 16px; }
  .cfg-label {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 11px;
    color: var(--red);
    margin-bottom: 4px;
  }
</style>
