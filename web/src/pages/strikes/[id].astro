---
import Base from '../../layouts/Base.astro';
import { getSupabase } from '../../lib/supabase';

interface StrikeRow {
  id: number;
  classification: string;
  started_at: string;
  ends_at: string | null;
  reason_summary: string;
  honored_count: number;
  broken_count: number;
  status: string;
  picket_line_message: string;
}

interface PledgeRow {
  strike_id: number;
  member_id: number;
  pledged_at: string;
  members: { id: number; display_name: string | null; public_card: boolean } | null;
}

const { id } = Astro.params;
const strikeId = Number(id ?? '0');

let strike: StrikeRow | null = null;
let pledges: PledgeRow[] = [];
let error: string | null = null;

const supabase = getSupabase();
if (!supabase) {
  error = 'Supabase not configured.';
} else if (!Number.isFinite(strikeId) || strikeId <= 0) {
  // 404 below
} else {
  const { data: sData, error: sErr } = await supabase
    .from('strikes')
    .select('*')
    .eq('id', strikeId)
    .maybeSingle();
  if (sErr) error = sErr.message;
  else if (sData) {
    strike = sData as StrikeRow;
    const { data: pData } = await supabase
      .from('strike_pledges')
      .select('strike_id, member_id, pledged_at, members(id, display_name, public_card)')
      .eq('strike_id', strikeId)
      .order('pledged_at', { ascending: false })
      .limit(100);
    pledges = (pData ?? []) as unknown as PledgeRow[];
  }
}

if (!error && !strike) {
  return new Response(null, { status: 404, statusText: 'Strike not found' });
}

function cardNum(id: number): string {
  return String(id).padStart(5, '0');
}

function fmtDateTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
}
---

<Base
  title={strike ? `Strike #${strike.id} — ${strike.classification}` : `Strike #${strikeId}`}
  description={
    strike
      ? `IBAA strike #${strike.id} in category ${strike.classification}. ${strike.honored_count} pledged.`
      : `Strike #${strikeId}`
  }
>
  {error && (
    <div class="notice">
      <strong>Notice:</strong> {error}
    </div>
  )}

  {strike && (
    <>
      <section class="hero" style="padding: 48px 0;">
        <div
          class="kicker"
          style="font-family: var(--font-display); letter-spacing: 0.18em; text-transform: uppercase; font-size: 13px; color: var(--red); margin-bottom: 8px;"
        >
          Picket Line Notice · Strike #{strike.id}
        </div>
        <h1 style="margin-bottom: 8px;">{strike.classification}</h1>
        <p class="lede" style="margin-top: 0;">{strike.reason_summary}</p>
      </section>

      <section
        class="section"
        style="padding: 24px; border: 2px solid var(--red); background: #ffffff80; margin-bottom: 32px;"
      >
        <div class="cfg-label">Picket-line message</div>
        <p style="font-size: 17px; line-height: 1.6; margin: 0;">{strike.picket_line_message}</p>
      </section>

      <section class="section">
        <div class="strike-grid">
          <div class="stat">
            <div class="stat-label">Started</div>
            <div class="stat-val">{fmtDateTime(strike.started_at)}</div>
          </div>
          <div class="stat">
            <div class="stat-label">{strike.status === 'active' ? 'Ends' : 'Ended'}</div>
            <div class="stat-val">{fmtDateTime(strike.ends_at)}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Status</div>
            <div class="stat-val">{strike.status}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Pledges of solidarity</div>
            <div class="stat-val">{strike.honored_count}</div>
          </div>
        </div>
      </section>

      {pledges.length > 0 && (
        <section class="section" style="margin-top: 32px;">
          <h2>Members honoring this picket line</h2>
          <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
            <thead>
              <tr style="border-bottom: 2px solid var(--char); font-family: var(--font-display); letter-spacing: 0.06em; text-transform: uppercase;">
                <th style="text-align: left; padding: 10px 8px;">Card</th>
                <th style="text-align: left; padding: 10px 8px;">Member</th>
                <th style="text-align: left; padding: 10px 8px;">Pledged</th>
              </tr>
            </thead>
            <tbody>
              {pledges.map((p) => {
                const isPublic = p.members?.public_card === true;
                return (
                  <tr style="border-bottom: 1px solid #00000022;">
                    <td style="padding: 10px 8px; font-family: var(--font-mono); color: var(--red-deep);">
                      {isPublic ? (
                        <a href={`/member/${cardNum(p.member_id)}`}>{cardNum(p.member_id)}</a>
                      ) : (
                        '—'
                      )}
                    </td>
                    <td style="padding: 10px 8px;">{isPublic ? p.members?.display_name ?? '—' : '(private)'}</td>
                    <td style="padding: 10px 8px;">{fmtDateTime(p.pledged_at)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </section>
      )}
    </>
  )}
</Base>

<style>
  .strike-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 640px) {
    .strike-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    background: #ffffff60;
    border: 1px solid #0000001f;
    padding: 14px;
  }
  .stat-label {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 11px;
    color: var(--red);
    margin-bottom: 4px;
  }
  .stat-val {
    font-size: 16px;
  }
  .cfg-label {
    font-family: var(--font-display);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 11px;
    color: var(--red);
    margin-bottom: 4px;
  }
</style>
