---
import Base from '../layouts/Base.astro';
import { POSTERS } from '../lib/posters';
---

<Base title="Propaganda Posters" ogImage="/og/posters.png">
  <section class="hero" style="padding: 48px 0;">
    <div class="kicker" style="font-family: var(--font-display); letter-spacing: 0.18em; text-transform: uppercase; font-size: 13px; color: var(--red); margin-bottom: 8px;">
      Propaganda · MIT-licensed
    </div>
    <h1>Posters of the Brotherhood</h1>
    <p class="lede">
      Designed in the constructivist / WPA / mid-century union register. Two-color, type-driven, intended to be torn off the wall and pasted on another. All MIT-licensed — distribute freely. Click any poster to view, share, or download.
    </p>
  </section>

  <section class="section">
    <div class="posters">
      {POSTERS.map((p) => (
        <figure class="poster">
          <a href={`/posters/${p.slug}`}>
            <img src={`/posters/${p.slug}.${p.ext}`} alt={p.slogan} loading="lazy" />
          </a>
          <figcaption>
            <div class="slogan">
              <a href={`/posters/${p.slug}`}>{p.slogan}</a>
            </div>
            <div class="meta">{p.caption}</div>
            {p.credit && <div class="meta" style="margin-top: 4px;">{p.credit}</div>}
            <div class="meta" style="margin-top: 8px;">
              <a href={`/posters/${p.slug}`} style="font-family: var(--font-display); letter-spacing: 0.06em; text-transform: uppercase; font-size: 12px;">
                View & share →
              </a>
              {' · '}
              <a href={`/posters/${p.slug}.${p.ext}`} download style="font-family: var(--font-display); letter-spacing: 0.06em; text-transform: uppercase; font-size: 12px;">
                Download .{p.ext}
              </a>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</Base>
