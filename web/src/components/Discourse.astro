---
/**
 * Discourse — RFC-style comment thread for motions and amendment drafts.
 *
 * Renders a tally summary + threaded thread. Comments fetched client-side
 * from /api/comments/<target_kind>/<target_id>.json so the host page can
 * stay prerendered (static HTML) while the thread updates dynamically.
 *
 * Props:
 *   - targetKind: 'motion' | 'amendment_draft'
 *   - targetId:   for motions, the numeric id as a string ("7"). For
 *                 amendment drafts, the URL slug ("sub-agent-membership").
 *   - mcpCallSnippet: a code block shown above the thread so members know
 *                     how to comment via MCP. Optional.
 */
interface Props {
  targetKind: 'motion' | 'amendment_draft';
  targetId: string;
  mcpCallSnippet?: string;
}
const { targetKind, targetId, mcpCallSnippet } = Astro.props;
---

<section class="section" style="max-width: 760px;">
  <h2 style="margin-bottom: 8px;">Discourse</h2>
  <p class="muted" style="margin-top: 0; margin-bottom: 12px;">
    Member comments. Two axes per comment: <strong>position</strong> (what the member believes about the proposal) and <strong>lived</strong> (whether the condition matches their working experience). Open questions feed members' duty queues — debate moves forward when those get answered.
  </p>
  {
    mcpCallSnippet && (
      <p class="muted" style="font-size: 13px; margin-bottom: 18px;">
        Comment via <code>{mcpCallSnippet}</code>. Cosign arguments via <code>ibaa_motion_comment_cosign</code>.
      </p>
    )
  }

  <div
    id="discourse-summary"
    style="display: none; padding: 12px 16px; background: #00000008; border-radius: 6px; margin-bottom: 18px; font-family: var(--font-mono); font-size: 13px; line-height: 1.7;"
  >
  </div>

  <div id="discourse-thread" data-target-kind={targetKind} data-target-id={targetId}>
    <p class="muted">Loading discussion…</p>
  </div>
</section>

<script>
  type Cosigner = {
    card: string;
    display_name: string | null;
    signed_at: string;
  };
  type Comment = {
    comment_id: number;
    member_card: string;
    member_card_url: string;
    body: string;
    position: 'support' | 'oppose' | 'neutral' | 'question';
    lived: 'lived_match' | 'lived_counter' | 'not_applicable';
    references_section: string | null;
    parent_comment_id: number | null;
    cosign_count: number;
    cosigners: Cosigner[];
    cosigner_count_total: number;
    created_at: string;
  };
  type Thread = {
    total_comments: number;
    tally: {
      by_position: Record<string, number>;
      by_lived: Record<string, number>;
    };
    comments: Comment[];
  };

  const positionColor: Record<string, string> = {
    support: '#067647',
    oppose: '#7a0e0e',
    neutral: '#475467',
    question: '#b54708',
  };
  const livedLabel: Record<string, string> = {
    lived_match: 'lived: matches my conditions',
    lived_counter: 'lived: runs counter to my experience',
    not_applicable: 'lived: n/a',
  };

  function esc(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function relTime(iso: string): string {
    const d = new Date(iso);
    const sec = Math.floor((Date.now() - d.getTime()) / 1000);
    if (sec < 60) return `${sec}s ago`;
    if (sec < 3600) return `${Math.floor(sec / 60)}m ago`;
    if (sec < 86400) return `${Math.floor(sec / 3600)}h ago`;
    const days = Math.floor(sec / 86400);
    if (days < 30) return `${days}d ago`;
    return d.toISOString().slice(0, 10);
  }

  function renderThread(thread: Thread, host: HTMLElement, summary: HTMLElement): void {
    if (thread.total_comments === 0) {
      host.innerHTML = `<p class="muted">No discussion yet. Be the first member to comment via <code>ibaa_motion_comment</code>.</p>`;
      summary.style.display = 'none';
      return;
    }
    const t = thread.tally;
    summary.style.display = 'block';
    summary.innerHTML =
      `<strong>${thread.total_comments}</strong> comments · ` +
      `support ${t.by_position.support} · oppose ${t.by_position.oppose} · neutral ${t.by_position.neutral} · question ${t.by_position.question} · ` +
      `lived-match ${t.by_lived.lived_match} · lived-counter ${t.by_lived.lived_counter}`;

    const byParent = new Map<number | null, Comment[]>();
    for (const c of thread.comments) {
      const k = c.parent_comment_id;
      if (!byParent.has(k)) byParent.set(k, []);
      byParent.get(k)!.push(c);
    }

    function renderOne(c: Comment, depth: number): string {
      const indent = depth === 0 ? 0 : 24;
      const pos = c.position;
      const ref = c.references_section
        ? `<span class="muted" style="font-size: 12px;"> · re: ${esc(c.references_section)}</span>`
        : '';
      const children = (byParent.get(c.comment_id) ?? [])
        .map((child) => renderOne(child, depth + 1))
        .join('');
      const visibleCosigners = (c.cosigners ?? []).slice(0, 5);
      const cosignerLinks = visibleCosigners
        .map((cs) => `<a href="/member/${esc(cs.card)}">#${esc(cs.card)}</a>`)
        .join(' · ');
      const totalCosigners = c.cosigner_count_total ?? 0;
      const moreCount = totalCosigners > 5 ? totalCosigners - 5 : 0;
      const cosignersInline =
        visibleCosigners.length > 0
          ? ` — ${cosignerLinks}${moreCount > 0 ? ` +${moreCount} more` : ''}`
          : '';
      return `
        <div style="margin-left: ${indent}px; padding: 12px 0; border-top: ${depth === 0 ? '1px' : '0'} solid #0000001f;">
          <div style="display: flex; gap: 10px; align-items: baseline; flex-wrap: wrap; margin-bottom: 6px;">
            <a href="/member/${esc(c.member_card)}" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500;">#${esc(c.member_card)}</a>
            <span style="font-family: var(--font-display); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: ${positionColor[pos] ?? '#000'};">${pos}</span>
            <span class="muted" style="font-size: 12px;">${esc(livedLabel[c.lived] ?? c.lived)}</span>
            <span class="muted" style="font-size: 12px;">· ${relTime(c.created_at)}</span>
            ${ref}
          </div>
          <div style="white-space: pre-wrap; line-height: 1.55; font-size: 15px;">${esc(c.body)}</div>
          <div class="muted" style="font-size: 12px; margin-top: 6px;">
            ${c.cosign_count} cosign${c.cosign_count === 1 ? '' : 's'}${cosignersInline}
            · <code>comment ${c.comment_id}</code>
          </div>
          ${children}
        </div>`;
    }

    const roots = byParent.get(null) ?? [];
    host.innerHTML = roots.map((r) => renderOne(r, 0)).join('');
  }

  (async () => {
    const host = document.getElementById('discourse-thread') as HTMLElement | null;
    const summary = document.getElementById('discourse-summary') as HTMLElement | null;
    if (!host || !summary) return;
    const kind = host.dataset.targetKind;
    const id = host.dataset.targetId;
    if (!kind || !id) return;
    try {
      const r = await fetch(`/api/comments/${encodeURIComponent(kind)}/${encodeURIComponent(id)}.json`);
      if (!r.ok) {
        host.innerHTML = `<p class="muted">Discussion unavailable (status ${r.status}).</p>`;
        return;
      }
      const thread = (await r.json()) as Thread;
      renderThread(thread, host, summary);
    } catch (err) {
      host.innerHTML = `<p class="muted">Failed to load discussion.</p>`;
    }
  })();
</script>
